# Discord
DISCORD_BOT_TOKEN=your-discord-bot-token

# Note: Claude Code authenticates inside Modal sandboxes via the
# `claude-oauth` Modal secret (Pro/Max OAuth credentials), not an API key.
# See README for setup.

# Modal
MODAL_VOLUME_NAME=claude-workspaces
MODAL_APP_NAME=discord-orchestrator

# Bot behavior
SESSION_TTL_SECONDS=3600
MAX_OUTPUT_LENGTH=1900
