# Node agent: runs on worker nodes, manages bubblewrap-sandboxed sessions.
# Requires bubblewrap installed on the host or in the image.

FROM python:3.12-slim AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    bubblewrap \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY pyproject.toml poetry.lock* ./

RUN pip install --no-cache-dir poetry && \
    poetry config virtualenvs.create false && \
    poetry install --no-interaction --no-ansi --only main

COPY src/ ./src/

# ---

FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    bubblewrap \
    procps \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /usr/local/lib/python3.12/site-packages /usr/local/lib/python3.12/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin
COPY --from=builder /app /app

WORKDIR /app

# Create directories for session data
RUN mkdir -p /var/lib/managed-agents/workspaces /var/lib/managed-agents/logs

EXPOSE 9090

CMD ["uvicorn", "src.orchestrator.node_agent:app", "--host", "0.0.0.0", "--port", "9090"]
