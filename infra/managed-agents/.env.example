# ============================================================================
# Managed Agents Environment Configuration
# ============================================================================
# Copy this file to .env and update values for your environment

# ============================================================================
# API Server Configuration
# ============================================================================
API_PORT=8000
LOG_LEVEL=info
ENVIRONMENT=development

# ============================================================================
# PostgreSQL Configuration
# ============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=managed_agents
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/managed_agents

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# ============================================================================
# LLM Backend Configuration
# ============================================================================
# Choose between: "anthropic" or "vllm"
LLM_DEFAULT_BACKEND=anthropic

# Anthropic API Configuration
ANTHROPIC_API_KEY=your-api-key-here
LLM_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# vLLM Configuration (if using vLLM backend)
LLM_VLLM_ENDPOINT=http://localhost:8001/v1
LLM_VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# ============================================================================
# Session Management
# ============================================================================
SESSION_NAMESPACE=managed-agents-sessions
SESSION_MAX_CONCURRENT=50
SESSION_TTL_SECONDS=3600

# Runtime image
RUNTIME_IMAGE=managed-agents-runtime:latest
RUNTIME_CPU_REQUEST=1
RUNTIME_MEMORY_REQUEST=2Gi
RUNTIME_CPU_LIMIT=2
RUNTIME_MEMORY_LIMIT=4Gi

# ============================================================================
# Kubernetes Configuration (for Helm deployment)
# ============================================================================
# Namespace where managed-agents is deployed
K8S_NAMESPACE=default

# Service account name
K8S_SERVICE_ACCOUNT=managed-agents-api

# ============================================================================
# Monitoring and Observability
# ============================================================================
METRICS_ENABLED=false
TRACING_ENABLED=false
LOG_FORMAT=json

# ============================================================================
# Development Configuration
# ============================================================================
DEBUG=false
RELOAD=true  # Enable hot-reload for development
